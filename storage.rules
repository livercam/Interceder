rules_version = '2';

// ============================================================
// REGRAS DO FIREBASE STORAGE
// ============================================================

service firebase.storage {
  match /b/{bucket}/o {
    
    // 📁 Pasta de anúncios
    // Admin pode fazer upload e deletar. Usuários logados podem ler.
    match /anuncios/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null 
                    && request.auth.token.email == "peterdonie@gmail.com";
    }

    // 📁 Pasta de fotos de perfil: perfis/{uid}.jpg
    // Cada usuário só pode escrever no arquivo com seu próprio UID.
    // Usamos matches() com regex porque startWith() não existe em Storage rules.
    match /perfis/{fileName} {
      allow read: if true;
      allow write: if request.auth != null 
                    && fileName.matches(request.auth.uid + '\\.jpg');
    }

    // 📁 Pasta de áudios: audio/{userId}/{nome}
    // Cada usuário pode escrever apenas na sua própria pasta
    match /audio/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 📁 Pasta de feed: feed/{celulaId}/{nome}
    match /feed/{celulaId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 📁 Demais arquivos
    // Liberado para leitura pública, escrita apenas para admin
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null 
                    && request.auth.token.email == "peterdonie@gmail.com";
    }
  }
}