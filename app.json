{
  "expo": {
    "name": "Interceder",
    "slug": "Interceder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.campos.interceder"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFBF5",
        "foregroundImage": "./assets/logo.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.campos.interceder",
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-google-signin/google-signin",
      "expo-build-properties",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "backgroundColor": "#FFFBF5"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Permita que o Interceder acesse seu microfone para gravar mensagens de voz."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "03375173-46aa-4d14-acc6-8dfbbecc0ee8"
      }
    }
  }
}
